---
/**
 * The single sanctioned client island. Cycles theme between
 * light → dark → auto and persists the choice in localStorage.
 * The actual data-theme attribute is resolved by the inline
 * bootstrap script in BaseLayout so we never flash.
 */
---

<button
  type="button"
  class="theme-toggle"
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <span class="icon icon-sun" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </span>
  <span class="icon icon-moon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </span>
  <span class="icon icon-auto" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 3a9 9 0 0 0 0 18z" fill="currentColor" stroke="none" />
    </svg>
  </span>
  <span class="label" data-theme-label>Auto</span>
</button>

<script>
  type Mode = 'light' | 'dark' | 'auto';
  const ORDER: Mode[] = ['auto', 'light', 'dark'];
  const NEXT: Record<Mode, Mode> = { auto: 'light', light: 'dark', dark: 'auto' };
  const LABEL: Record<Mode, string> = { auto: 'Auto', light: 'Light', dark: 'Dark' };

  function currentMode(): Mode {
    const stored = localStorage.getItem('theme');
    return stored === 'light' || stored === 'dark' || stored === 'auto' ? stored : 'auto';
  }

  function applyMode(mode: Mode) {
    const root = document.documentElement;
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const resolved = mode === 'auto' ? (prefersDark ? 'dark' : 'light') : mode;
    root.dataset.theme = resolved;
    root.dataset.themeMode = mode;
    document
      .querySelectorAll<HTMLElement>('[data-theme-toggle]')
      .forEach((btn) => {
        btn.dataset.mode = mode;
        const label = btn.querySelector<HTMLElement>('[data-theme-label]');
        if (label) label.textContent = LABEL[mode];
        btn.setAttribute('aria-label', `Color theme: ${LABEL[mode]}. Click to change.`);
      });
  }

  // Initialize labels on hydration (the inline bootstrap already set data-theme).
  applyMode(currentMode());

  // React to OS changes only while in auto mode.
  const mq = window.matchMedia('(prefers-color-scheme: dark)');
  mq.addEventListener('change', () => {
    if (currentMode() === 'auto') applyMode('auto');
  });

  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = NEXT[currentMode()];
      localStorage.setItem('theme', next);
      applyMode(next);
    });
  });

  // Silence unused vars in strict TS — kept for documentation.
  void ORDER;
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: var(--s-2) var(--s-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--fg-muted);
    font-size: var(--fs-xs);
    font-weight: var(--fw-medium);
    transition: color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }
  .theme-toggle:hover {
    color: var(--fg-default);
    border-color: var(--border-strong);
  }

  .icon { display: none; line-height: 0; }
  .theme-toggle[data-mode="light"] .icon-sun  { display: inline-flex; }
  .theme-toggle[data-mode="dark"]  .icon-moon { display: inline-flex; }
  .theme-toggle[data-mode="auto"]  .icon-auto { display: inline-flex; }

  /* While JS hasn't hydrated, show the sun (light) as a sensible default. */
  .theme-toggle:not([data-mode]) .icon-sun { display: inline-flex; }

  .label {
    letter-spacing: 0.02em;
  }
</style>
